{
  "expo": {
    "name": "Linkery Notes",
    "slug": "linkery-notes",
    "version": "1.0.0",
    "description": "Linkery Notes - Smart link saving with MongoDB sync",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "linkery-notes",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#080C10"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ganeshbagal.linkerynotes"
    },
    "android": {
      "backgroundColor": "#080C10",
      "package": "com.ganeshbagal.linkerynotes"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
